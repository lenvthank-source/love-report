# OpenCage API Key for Geocoding (required)
OPENCAGE_API_KEY=your_opencage_api_key_here

# VedAstro API Key (optional, defaults to FreeAPIUser)
VEDASTRO_API_KEY=FreeAPIUser

# OpenRouter API Key and Model (required)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-5.4-mini

# SendPulse SMTP Credentials (required for transactional emails)
SENDPULSE_SMTP_PORT=465
SENDPULSE_SMTP_USER=your_sendpulse_login_email_here
SENDPULSE_SMTP_PASSWORD=your_sendpulse_smtp_api_key_here
SENDER_EMAIL=your_authenticated_sender_email_here
SENDER_NAME=your_display_sender_name_here

# Razorpay Webhook Secret (required for secure server-to-server webhook confirmation)
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

